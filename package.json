{
  "name": "0base-exporter",
  "version": "1.0.0",
  "description": "Prometheus exporter for validator and wallet metrics across multiple blockchain networks.",
  "license": "MIT",
  "author": "jjangg96@gmail.com",
  "homepage": "https://github.com/0base-vc/0base-exporter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0base-vc/0base-exporter.git"
  },
  "bugs": {
    "url": "https://github.com/0base-vc/0base-exporter/issues"
  },
  "keywords": [
    "prometheus",
    "exporter",
    "blockchain",
    "validator",
    "solana",
    "cosmos",
    "evm"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "0base-exporter": "./dist/index.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "README.ko.md"
  ],
  "scripts": {
    "clean": "rm -rf dist coverage tsconfig.build.tsbuildinfo",
    "copy:assets": "copyfiles -u 1 \"src/**/*.json\" dist",
    "build": "npm run clean && tsc --project tsconfig.build.json && npm run copy:assets && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "dev": "nodemon --watch src --ext ts,json --exec ts-node src/index.ts",
    "release:pack": "npm run build && npm pack",
    "start": "node dist/index.js",
    "start:build": "npm run build && node dist/index.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "eslint . && npm run lint:abi",
    "lint:fix": "eslint . --fix && npm run lint:abi",
    "lint:abi": "ts-node scripts/lint-abi-json.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "docs:lint": "markdownlint-cli2 \"README*.md\" \"CHANGELOG.md\" \"CONTRIBUTING.md\" \"SECURITY.md\" \"CODE_OF_CONDUCT.md\" \"GOVERNANCE.md\" \"MAINTAINERS.md\" \"SUPPORT.md\" \"docs/**/*.md\" \".github/pull_request_template.md\"",
    "ci:verify": "npm run typecheck && npm run lint && npm run format:check && npm run docs:lint && npm test && npm audit --omit=dev && npm run build && npm pack --dry-run",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@marinade.finance/ds-sam-sdk": "^0.0.51",
    "axios": "^1.18.1",
    "express": "^5.2.1",
    "lodash": "^4.18.1",
    "morgan": "^1.11.0",
    "prom-client": "^15.1.3",
    "web3": "^4.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.2",
    "@types/iarna__toml": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.20",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.13.3",
    "@types/supertest": "^7.2.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^16.2.6",
    "markdownlint-cli2": "^0.22.1",
    "nock": "^14.0.16",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  },
  "overrides": {
    "qs": "6.15.2",
    "smol-toml": "1.6.1",
    "diff": "4.0.4",
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "anymatch": {
      "picomatch": "2.3.2"
    },
    "readdirp": {
      "picomatch": "2.3.2"
    },
    "copyfiles": {
      "minimatch": {
        "brace-expansion": "1.1.13"
      }
    },
    "markdownlint-cli2": {
      "js-yaml": "4.3.0",
      "markdown-it": "14.2.0"
    },
    "follow-redirects": "1.16.0",
    "ws": "8.21.0",
    "@typescript-eslint/typescript-estree": {
      "brace-expansion": "5.0.6"
    }
  }
}
