{
  "name": "0base-exporter",
  "version": "1.0.0",
  "description": "Prometheus exporter for validator and wallet metrics across multiple blockchain networks.",
  "license": "MIT",
  "author": "jjangg96@gmail.com",
  "homepage": "https://github.com/0base-vc/0base-exporter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0base-vc/0base-exporter.git"
  },
  "bugs": {
    "url": "https://github.com/0base-vc/0base-exporter/issues"
  },
  "keywords": [
    "prometheus",
    "exporter",
    "blockchain",
    "validator",
    "solana",
    "cosmos",
    "evm"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "0base-exporter": "./dist/index.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "README.ko.md"
  ],
  "scripts": {
    "clean": "rm -rf dist coverage tsconfig.build.tsbuildinfo",
    "copy:assets": "copyfiles -u 1 \"src/**/*.json\" dist",
    "build": "npm run clean && tsc --project tsconfig.build.json && npm run copy:assets",
    "typecheck": "tsc --noEmit",
    "dev": "nodemon --watch src --ext ts,json --exec ts-node src/index.ts",
    "release:pack": "npm run build && npm pack",
    "start": "node dist/index.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "eslint . && npm run lint:abi",
    "lint:fix": "eslint . --fix && npm run lint:abi",
    "lint:abi": "ts-node scripts/lint-abi-json.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "docs:lint": "markdownlint-cli2 \"README*.md\" \"CHANGELOG.md\" \"CONTRIBUTING.md\" \"SECURITY.md\" \"CODE_OF_CONDUCT.md\" \"docs/**/*.md\" \".github/pull_request_template.md\"",
    "ci:verify": "npm run typecheck && npm run lint && npm run format:check && npm run docs:lint && npm test && npm run build && npm pack --dry-run",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@marinade.finance/ds-sam-sdk": "^0.0.46",
    "axios": "^1.7.2",
    "express": "^4.22.1",
    "lodash": "^4.18.1",
    "morgan": "^1.10.1",
    "prom-client": "^14.1.1",
    "web3": "^4.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/express": "^5.0.4",
    "@types/iarna__toml": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.20",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.10.1",
    "@types/supertest": "^6.0.3",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.6",
    "markdownlint-cli2": "^0.22.0",
    "nock": "^14.0.10",
    "nodemon": "^3.1.3",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2"
  },
  "overrides": {
    "body-parser": "1.20.4",
    "path-to-regexp": "0.1.13",
    "qs": "6.15.1",
    "smol-toml": "1.6.1",
    "diff": "4.0.4",
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "anymatch": {
      "picomatch": "2.3.2"
    },
    "readdirp": {
      "picomatch": "2.3.2"
    },
    "copyfiles": {
      "minimatch": {
        "brace-expansion": "1.1.13"
      }
    }
  }
}
